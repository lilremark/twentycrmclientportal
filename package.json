{
  "name": "twentycrmclientportal",
  "version": "1.4.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": "10.9.8"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    },
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:runtime": "rm -rf .runtime && mkdir -p .runtime && esbuild scripts/migrate.ts --bundle --platform=node --format=cjs --target=node22 --outfile=.runtime/migrate.cjs && esbuild scripts/bootstrap-admin.ts --bundle --platform=node --format=cjs --target=node22 --outfile=.runtime/bootstrap-admin.cjs",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.20",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
